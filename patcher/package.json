{
  "name": "matchu-patchu",
  "version": "0.2.4",
  "description": "The unified-diff patcher that's tolerant of form, strict about intent: repairs and applies sloppy AI-generated diffs when the intent is clear, fails precisely when it isn't.",
  "license": "Apache-2.0",
  "author": "Ben Albahari",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/typebulb/matchu-patchu.git",
    "directory": "patcher"
  },
  "homepage": "https://github.com/typebulb/matchu-patchu/tree/main/patcher#readme",
  "bugs": "https://github.com/typebulb/matchu-patchu/issues",
  "keywords": [
    "diff",
    "patch",
    "unified-diff",
    "apply-patch",
    "fuzzy-matching",
    "typescript",
    "llm",
    "ai-agent",
    "code-editing"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "matchu-patchu": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "!dist/**/*.map",
    "NOTICE",
    "description.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc --build",
    "clean": "rimraf dist",
    "prepublishOnly": "node ../scripts/require-pnpm.mjs",
    "prepare": "tsc --build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:core": "vitest run core",
    "test:regression": "vitest run regression"
  },
  "devDependencies": {
    "@types/node": "^25.2.3",
    "rimraf": "^6.0.1",
    "typescript": "^5.8.3",
    "vitest": "^2.1.9"
  }
}

